                                                        ">รฃยยตรฃยยรฃยยฟรฃยยE/a>
                                                    {% elif 'รฃยยรฃยยงรฃยยEรฃยยรฃยยรฃยยฏรฃยยน' in category_data.category %}
                                                        <input type="checkbox" class="form-check-input" checked style="
