                                                                background-color: {{ item.bg_color }};
                                                                font-size: 14px;
                                                                font-weight: bold;
                                                                color: {{ item.text_color }};
                                                            ">รยE/span>
                                                        {% elif '30รฆยยฅ' in item.name %}
                                                            <span style="
                                                                display: inline-flex;
                                                                align-items: center;
                                                                justify-content: center;
                                                                width: 18px;
                                                                height: 18px;
