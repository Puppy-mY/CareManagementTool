                                                    {% elif 'รฃยยE๏ผรฃยยรฃยยซรจยกยE in category_data.category %}
                                                        <div style="
                                                            background-color: {{ item.bg_color }};
                                                            border: 1px solid {{ item.border_color }};
                                                            color: {{ item.text_color }};
                                                            padding: 8px;
                                                        ">รจยกยรฃยยรฃยยผรฃยยฟ</div>
                                                    {% elif 'รคยปยรจยญยทรฅยบยฆ' in category_data.category %}
