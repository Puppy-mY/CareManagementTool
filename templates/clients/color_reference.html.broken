                                                                border-radius: 50%;
                                                                background-color: {{ item.bg_color }};
                                                                font-size: 8px;
                                                                font-weight: bold;
                                                                color: {{ item.text_color }};
                                                            ">15</span>
                                                        {% else %}
                                                            <span style="
                                                                display: inline-flex;
                                                                align-items: center;
                                                                justify-content: center;
                                                                width: 18px;
                                                                height: 18px;
                                                                border: 1px solid {{ item.border_color }};
                                                                border-radius: 50%;
                                                                background-color: {{ item.bg_color }};
                                                                font-size: 8px;
                                                                font-weight: bold;
                                                                color: {{ item.text_color }};
                                                            ">60</span>
                                                        {% endif %}
                                                    {% elif 'รฆยยรคยฝย๏ผรฃยยฟรฃยยณ' in category_data.category %}
                                                        <button class="btn btn-outline-secondary btn-sm" style="
                                                            background-color: {{ item.bg_color }};
                                                            border-color: {{ item.border_color }};
                                                            color: {{ item.text_color }};
                                                            font-size: 11px;
                                                            padding: 2px 8px;
                                                            pointer-events: none;
                                                        ">รฆยยรคยฝยE/button>
                                                    {% elif 'รฆยยรคยฝยรฃยยขรฃยยครฃยยณรฃยยณ' in category_data.category %}
                                                        <i class="fas
                                                            {% if 'รจยฉยณรงยดยฐรจยกยจรงยคยบ' in item.name %}fa-eye
                                                            {% elif 'รฆยยEรงยทยจรฉยยE in item.name %}fa-edit
                                                            {% elif 'รฉยยรฅยบยฆรฉยกยรจยฉยฆรงยฎยE in item.name %}fa-calculator
                                                            {% elif 'รฃยยขรฃยยปรฃยยนรฃยยกรฃยยณรฃยยE in item.name %}fa-clipboard-list
                                                            {% elif 'รฆยยธรฉยกยรคยฝย๏ผ' in item.name %}fa-file-alt
                                                            {% elif 'รคยบยรฅยฎยรงยฎยกรงยยE in item.name %}fa-calendar-check
                                                            {% elif 'รฅยฑยฅรฆยญยดรฃยยปรจยจยรฉยยฒ' in item.name %}fa-chart-line
                                                            {% elif 'รฅยยฐรฅยยทรฃยยปรฅยยบรฅยยE in item.name %}fa-print
                                                            {% endif %}"
                                                        style="
