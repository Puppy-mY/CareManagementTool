                                                    {% elif 'รฉยยธรฆยย๏ผรฃยยฟรฃยยณ' in category_data.category %}
                                                        <button class="btn btn-outline-secondary btn-sm" style="
                                                            background-color: {{ item.bg_color }};
                                                            border-color: {{ item.border_color }};
                                                            color: {{ item.text_color }};
                                                            font-size: 0.875rem;
                                                            padding: 0.25rem 0.5rem;
                                                            pointer-events: none;
                                                        ">รฉยยธรฆยยE/button>
                                                    {% elif 'รฃยยซรฃยยผรฃยยฝรฃยยซ' in category_data.category %}
                                                        <button class="btn btn-outline-secondary btn-sm" style="
                                                            background-color: {{ item.bg_color }};
                                                            border-color: {{ item.border_color }};
                                                            color: {{ item.text_color }};
                                                            font-size: 0.875rem;
                                                            padding: 0.25rem 0.5rem;
                                                            pointer-events: none;
                                                        ">รฆยยชรฉยยธรฆยยE/button>
                                                    {% elif 'รฃยยกรฃยยครฃยยณรฃยยฟรฃยยE in category_data.category %}
                                                        <div style="
                                                            display: inline-block;
