.btn-animation-demo-3:hover {
    background-color: #f5f5f5 !important;
    color: #000000 !important;
    border-color: #999999 !important;
    transform: translateX(3px);
}

.btn-animation-demo-4:hover {
    background-color: #f5f5f5 !important;
    color: #000000 !important;
    border: 2px solid #999999 !important;
    padding: 3px 7px;
}

.animation-pattern-table tbody tr {
    cursor: pointer;
}

.copy-toast {
    position: fixed;
    top: 20px;
    right: 20px;
    background-color: #e8f5e8;
    color: #198754;
    border: 1px solid #198754;
    padding: 12px 24px;
    border-radius: 4px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    z-index: 9999;
    animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
    from {
        transform: translateX(400px);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // รฃยยขรฃยยรฃยยกรฃยยผรฃยยทรฃยยงรฃยยณรฃยยรฃยยฟรฃยยผรฃยยณรจยกย๏ผรฃยยฏรฃยยชรฃยยEรฃยยครฃยยรฃยยณรฃยยE
    const animationPatternRows = document.querySelectorAll('.animation-pattern-row');

    animationPatternRows.forEach(row => {
        row.addEventListener('click', function(e) {
            // รฃยยรฃยยฟรฃยยณรฃยยฎรฃยยรฃยยรฃยยผรฃยยครฃยยรฃยยณรฃยยรฃยยรฅยฆยจรฃยยรฃยยชรฃยยEรฃยยEรฃยย๏ผรฃยยฟรฃยยณรฃยยฏรฃยยชรฃยยEรฆยย๏ผรฅยยฆรงยยEรฃยยนรฃยยญรฃยยE๏ผ
            if (e.target.tagName === 'BUTTON') {
                return;
            }

            const patternNumber = this.getAttribute('data-pattern');
            let copyText = `/* รฃยยขรฃยยรฃยยกรฃยยผรฃยยทรฃยยงรฃยยณรฃยยรฃยยฟรฃยยผรฃยยณ${patternNumber} */\n`;
            copyText += `transition: all 0.2s ease;\n\n`;
            copyText += `/* รฃยยรฃยยรฃยยผรฆยยE*/\n`;
            copyText += `.btn:hover {\n`;

            // รฃยยรฃยยฟรฃยยผรฃยยณรฃยยรฃยยจรฃยยซรฃยยณรฃยยผรฃยยรฃยยรงยย๏ผ
            if (patternNumber === '0') {
                copyText += `    transform: translateY(-1px);\n`;
            } else if (patternNumber === '1') {
                copyText += `    transform: scale(1.05);\n`;
            } else if (patternNumber === '2') {
                copyText += `    box-shadow: 0 4px 8px rgba(0,0,0,0.2);\n`;
            } else if (patternNumber === '3') {
                copyText += `    transform: translateX(3px);\n`;
            } else if (patternNumber === '4') {
                copyText += `    border: 2px solid #999999;\n`;
                copyText += `    padding: 3px 7px; /* รฆยย รงยทยรฃยยรฅยคยชรฃยยรฃยยชรฃยย๏ผรฃยยpaddingรฃยยรจยชยฟรฆยยด */\n`;
            }

            copyText += `}`;

            // รฃยยฏรฃยยชรฃยยE๏ผรฃยย๏ผรฃยยรฃยยซรฃยยณรฃยย๏ผ
            navigator.clipboard.writeText(copyText).then(() => {
                showCopyToast(`รฃยยขรฃยยรฃยยกรฃยยผรฃยยทรฃยยงรฃยยณรฃยยรฃยยฟรฃยยผรฃยยณ${patternNumber}รฃยยฎรฃยยณรฃยยผรฃยยรฃยยรฃยยณรฃยย๏ผรฃยยรฃยยพรฃยยรฃยย`);
            }).catch(err => {
                console.error('รฃยยณรฃยย๏ผรฃยยซรฅยคยฑรฆยยรฃยยรฃยยพรฃยยรฃยย:', err);
                alert('รฃยยฏรฃยยชรฃยยE๏ผรฃยย๏ผรฃยยรฃยยธรฃยยฎรฃยยณรฃยย๏ผรฃยยซรฅยคยฑรฆยยรฃยยรฃยยพรฃยยรฃยย');
            });
        });
    });

    // รฃยยณรฃยย๏ผรฅยฎยรคยบยEรฃยยผรฃยยนรฃยยรจยกยจรงยคยบ
    function showCopyToast(message) {
        const toast = document.createElement('div');
        toast.className = 'copy-toast';
        toast.innerHTML = '<i class="fas fa-check-circle me-2"></i>' + message;
        document.body.appendChild(toast);

        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(400px)';
            setTimeout(() => {
                document.body.removeChild(toast);
            }, 300);
        }, 2000);
    }
});
</script>
{% endblock %}
