                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- รฃยยซรฃยยฉรฃยยผรฃยยรฃยยฟรฃยยผรฃยยณรฃยยฟรฃยยE-->
        <div class="tab-pane fade" id="color-pattern-main" role="tabpanel">
            <div class="pt-4 pb-3">
                <div class="card">
