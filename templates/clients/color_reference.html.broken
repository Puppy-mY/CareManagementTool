{% extends 'base.html' %}

{% block title %}รฃยยซรฃยยฉรฃยยผรฅยย๏ผ - {{ block.super }}{% endblock %}

{% block content %}
<style>
    /* รฃยยกรฃยยครฃยยณรฃยยฟรฃยย๏ผรฃยยนรฃยยฟรฃยยครฃยยซ๏ผรฅยยฉรงยยจรจยยEรงยดยฐรฃยยจรฅยยรฃยย๏ผ๏ผ*/
    #colorRefMainTabs {
        border-bottom: none;
        background-color: transparent;
        padding: 0;
        flex-wrap: nowrap;
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
        justify-content: space-between;
    }

    #colorRefMainTabs .nav-item {
        flex: 1;
        text-align: center;
        position: relative;
    }

    #colorRefMainTabs .nav-item:not(:last-child)::after {
        content: '';
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 1px;
        height: 60%;
        background-color: #dee2e6;
    }

    #colorRefMainTabs .nav-link {
        border: none;
        border-bottom: 3px solid transparent;
        border-radius: 0;
        padding: 0.75rem 1rem;
        font-weight: 500;
        color: #6c757d;
        background-color: transparent;
        margin-right: 0;
        transition: all 0.2s ease;
        white-space: nowrap;
        width: 100%;
    }

    #colorRefMainTabs .nav-link:hover {
        color: #495057;
        border-bottom-color: #dee2e6;
        background-color: transparent;
    }

    #colorRefMainTabs .nav-link.active {
        color: #495057;
        background-color: transparent;
        border-bottom: 3px solid #6c757d !important;
    }

    /* รฃยยตรฃยยรฃยยฟรฃยย๏ผรฃยยนรฃยยฟรฃยยครฃยยซ */
    #colorRefSubTabs {
        border-bottom: none !important;
        display: flex !important;
        margin-bottom: 0 !important;
    }

    #colorRefSubTabs .nav-item {
        flex: 1 !important;
        margin: 0 !important;
    }

    #colorRefSubTabs .nav-link {
        transition: all 0.2s ease;
        border: 1px solid #dee2e6 !important;
        border-bottom: none !important;
        border-top-left-radius: 0.375rem !important;
        border-top-right-radius: 0.375rem !important;
        width: 100% !important;
        margin: 0 !important;
    }

    #colorRefSubTabs .nav-link:not(.active) {
        background-color: #ffffff !important;
        color: #6c757d !important;
    }

    #colorRefSubTabs .nav-link.active {
        background-color: #f5f5f5 !important;
        border-color: #999 !important;
        color: #333 !important;
        border-bottom: none !important;
    }

    #colorRefSubTabs .nav-link:not(.active):hover {
        background-color: #e9ecef !important;
        color: #495057 !important;
    }

    .tab-pane-bordered {
        border: 1px solid #6c757d;
        border-radius: 0 0 0.375rem 0.375rem;
        background-color: white;
        padding: 1.5rem;
    }
</style>

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="fas fa-palette"></i> รฃยยซรฃยยฉรฃยยผรฅยย๏ผ</h1>
            <a href="{% url 'client_list' %}" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> รฆยยปรฃยยE
            </a>
        </div>
    </div>
</div>

<!-- รฃยยกรฃยยครฃยยณรฃยยฟรฃยยรฃยยรฃยยรฃยยฒรฃยยผรฃยยทรฃยยงรฃยยณ -->
<div class="bg-white border-bottom mb-0 pb-0">
    <div class="container-fluid px-4">
        <div class="row">
            <ul class="nav nav-tabs" id="colorRefMainTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="color-list-main-tab" data-bs-toggle="tab" data-bs-target="#color-list-main" type="button" role="tab">
                        รฃยยซรฃยยฉรฃยยผรคยธยรจยฆยง
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="color-pattern-main-tab" data-bs-toggle="tab" data-bs-target="#color-pattern-main" type="button" role="tab">
                        รฃยยซรฃยยฉรฃยยผรฃยยรฃยยฟรฃยยผรฃยยณ
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="animation-pattern-main-tab" data-bs-toggle="tab" data-bs-target="#animation-pattern-main" type="button" role="tab">
                        รฃยยขรฃยยรฃยยกรฃยยผรฃยยทรฃยยงรฃยยณรฃยยรฃยยฟรฃยยผรฃยยณ
                    </button>
                </li>
            </ul>
        </div>
    </div>
</div>

<!-- รฃยยฟรฃยยรฃยยณรฃยยณรฃยยEรฃยยE-->
<div class="container-fluid px-4">
    <div class="tab-content" id="colorRefMainTabContent">
        <!-- รฃยยซรฃยยฉรฃยยผรคยธยรจยฆยงรฃยยฟรฃยยE-->
        <div class="tab-pane fade show active" id="color-list-main" role="tabpanel">
            <div class="pt-4 pb-3">
                <div class="mb-0">
                    <ul class="nav nav-tabs" id="colorRefSubTabs" role="tablist">
