                                                            border: 2px solid {{ item.border_color }};
                                                            color: {{ item.text_color }};
                                                            padding: 8px;
                                                            border-radius: 4px;
                                                        ">รฃยยตรฃยยณรฃยยรฃยยซ</div>
                                                    {% endif %}
                                                </td>
                                                <td><button class="btn btn-sm btn-outline-secondary" style="font-size: 0.75rem;">&nbsp;</button></td>
                                                <td><button class="btn btn-sm btn-outline-secondary" style="font-size: 0.75rem;">&nbsp;</button></td>
                                                <td><button class="btn btn-sm btn-outline-secondary" style="font-size: 0.75rem;">&nbsp;</button></td>
                                            </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            {% endfor %}
                        </div>

                        <!-- รฃยยขรฃยยปรฃยยนรฃยยกรฃยยณรฃยยรคยฝย๏ผรฃยยตรฃยยรฃยยฟรฃยยE-->
                        <div class="tab-pane fade tab-pane-bordered" id="assessment-sub" role="tabpanel">
                            <p class="text-muted mb-4">
                                รฃยยขรฃยยปรฃยยนรฃยยกรฃยยณรฃยยรคยฝย๏ผรงยยปรฉยยขรฃยยงรคยฝยฟรงยยจรฃยยรฃยยรฃยยฆรฃยยEรฃยยซรฃยยฉรฃยยผรฃยยฎรคยธยรจยฆยงรฃยยงรฃยยรฃยยE
                            </p>

                            {% for category_data in assessment_colors %}
                            <div class="mb-4">
                                <h6 class="mb-3 fw-bold">{{ category_data.category }}</h6>
                                <div class="table-responsive">
                                    <table class="table table-bordered">
                                        <thead>
                                            <tr>
                                                <th style="width: 35%;">รฉย ยEรฅยยE/th>
                                                <th style="width: 20%;">รฃยยรฃยยนรฃยยE<br><small>๏ผรฃยยรฃยยรฃยยฉรฃยยซรฃยยรฏยผยE/small></th>
                                                <th style="width: 15%;">รจยยรฆยยฏรจยยฒ</th>
                                                <th style="width: 15%;">รฆยย รงยทยE/th>
                                                <th style="width: 15%;">รฆยยEรจยยฒ</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for item in category_data.items %}
                                            <tr>
                                                <td>{{ item.name }}</td>
                                                <td>
                                                    {% if 'รฆยยรคยฝย๏ผรฃยยฟรฃยยณ' in category_data.category %}
                                                        <button class="btn btn-sm" style="
                                                            background-color: {{ item.bg_color }};
