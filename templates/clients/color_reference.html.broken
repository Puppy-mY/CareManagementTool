                                                            border-bottom: 3px solid {{ item.bg_color }};
                                                            font-size: 0.875rem;
                                                        ">รฃยยฟรฃยยE/div>
                                                    {% elif 'รฃยยตรฃยยรฃยยฟรฃยยE in category_data.category %}
                                                        <a class="nav-link" style="
                                                            background-color: {{ item.bg_color }};
